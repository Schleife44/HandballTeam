# Sechsmeter Environment Variables
# Copy this file to .env and fill in your real values.

# FIREBASE CONFIG (You already have these in your firebase.js, but good to have here too)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# STRIPE CONFIG (Get these from your Stripe Dashboard)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# ADMIN CONFIG
VITE_ADMIN_UID=1gTmo9rM4FMZitP8YAcTDMHadT02
