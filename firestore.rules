rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User Profiles ─────────────────────────────────────────────────────────
    // Users can only read and write their own profile data
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ─── Teams (Recursive) ────────────────────────────────────────────────────
    // Temporary: Only authenticated users can access team data. 
    // In Phase 3, we will lock this down so only members can access their own team.
    match /teams/{teamId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // ─── Legacy Support (Sessions) ───────────────────────────────────────────
    match /sessions/{docId} {
      allow read, write: if request.auth != null;
    }

    // ─── Invitations ──────────────────────────────────────────────────────────
    // Anyone authenticated can read/create invites (Phase 4 will refine this)
    match /invites/{tokenId} {
      allow read, create: if request.auth != null;
    }

    // Default: Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
