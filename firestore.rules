rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User Profiles ─────────────────────────────────────────────────────────
    // Users can only read and write their own profile data
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ─── Teams (Recursive) ────────────────────────────────────────────────────
    // Only members registered in the team's 'members' subcollection or the owner can read/write.
    match /teams/{teamId}/{document=**} {
      allow read, write: if request.auth != null && (
        exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)) ||
        request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid
      );
    }

    // ─── Legacy Support (Sessions) ───────────────────────────────────────────
    match /sessions/{docId} {
      allow read, write: if request.auth != null;
    }

    // ─── Invitations ──────────────────────────────────────────────────────────
    // Anyone authenticated can read/create invites (Phase 4 will refine this)
    match /invites/{tokenId} {
      allow read, create: if request.auth != null;
    }

    // Default: Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
