rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User Profiles ─────────────────────────────────────────────────────────
    // Users can only read and write their own profile data
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ─── Teams ────────────────────────────────────────────────────────────────
    match /teams/{teamId} {
      // Allow any logged in user to create a team
      allow create: if request.auth != null;
      // Allow read/write if the user is a member OR the owner
      allow read, write: if request.auth != null && (
        exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)) ||
        request.auth.uid == resource.data.ownerUid
      );
    }

    // Members subcollection
    match /teams/{teamId}/members/{memberUid} {
      // Allow a user to add themselves as a member during team creation 
      // OR allow trainers to add members
      allow create, update: if request.auth != null && (
        request.auth.uid == memberUid ||
        get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid
      );
      allow read: if request.auth != null;
      allow delete: if request.auth != null && (
        request.auth.uid == memberUid ||
        get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.role == 'trainer'
      );
    }

    // Sub-collections of teams (games, etc.)
    match /teams/{teamId}/{subcollection}/{docId} {
      allow read, write: if request.auth != null && (
        exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid
      );
    }

    // ─── Legacy Support (Sessions) ───────────────────────────────────────────
    match /sessions/{docId} {
      allow read, write: if request.auth != null;
    }

    // ─── Invitations ──────────────────────────────────────────────────────────
    // Anyone authenticated can read/create invites (Phase 4 will refine this)
    match /invites/{tokenId} {
      allow read, create: if request.auth != null;
    }

    // Default: Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
